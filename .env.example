# Application
APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=shortly
DB_PASSWORD=shortly_secret
DB_NAME=shortly
DB_SSLMODE=disable

# Cache (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRY_HOURS=24

# Short URL
SHORT_URL_LENGTH=7
SHORT_URL_BASE_URL=http://localhost:8080

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Frontend (prefix required by Vite)
VITE_API_URL=http://localhost:8080/api/v1
